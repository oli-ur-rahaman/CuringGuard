# You can use Google Gemini (Recommended natively) or OpenAI
# Uncomment and populate the one you prefer.

# Required for Gemini (Recommended)
GOOGLE_API_KEY="your_google_gemini_api_key_here"

# Required if using OpenAI instead
# OPENAI_API_KEY="your_openai_api_key_here"

# Set the base directory of the project for File Tools
# Keep as '.' if running orchestrator.py from the root 'd:/CuringGuard', or absolute path.
PROJECT_ROOT_PATH="d:/CuringGuard"
